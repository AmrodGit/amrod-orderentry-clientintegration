script:pre-request {
  // Read environment variables
  const var1 = bru.getEnvVar('CUSTOMER_CODE');
  const var2 = bru.getEnvVar('CONTACT_ID');
  
  // Concatenate with ';'
  const combined = `${var2};${var1}`;
  
  var btoa = require('btoa');
  // Encode in Base64
  const encoded = btoa(combined);  // btoa() is available in Bruno
  
  // Set the custom header
  req.setHeader('x-gateway-impersonate', encoded);
  
}
