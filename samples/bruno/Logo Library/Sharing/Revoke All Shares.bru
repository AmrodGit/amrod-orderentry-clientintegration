}

body:graphql {
  mutation RevokeAllShares {
    revokeAllShares {
      errors {
        ... on ImpersonationRequiredException {
          message
        }
        ... on InputValidationException {
          message
          parameterName
          validationError
        }
      }
    }
  }
  
}

body:graphql:vars {
  {
    "input": {
      "id": ""
    }
  }
}
