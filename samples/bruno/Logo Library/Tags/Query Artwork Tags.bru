meta {
  name: Query Artwork Tags
  type: graphql
  seq: 5
}

post {
  url: 
  body: graphql
  auth: inherit
}

body:graphql {
  query GetArtowrkTags {
    artworkTags {
      canEdit
      color
      id
      name
      owner {
        customer {
          code
          name
        }
        contact {
          code
          emailAddress
        }
      }
    }
  }
}
